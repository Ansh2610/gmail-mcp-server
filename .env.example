# The dedicated Gmail account the briefing is sent FROM (used as the From header).
GMAIL_ADDRESS=your-sender@gmail.com

# OAuth2 client credentials from Google Cloud Console (type: Desktop app),
# with the Gmail API enabled and the gmail.send scope.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Refresh token for the sender account, minted once via:
#   npm run get-token
# (see README). Grants long-lived gmail.send access. Keep it secret.
GMAIL_REFRESH_TOKEN=your-refresh-token
