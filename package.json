{
  "name": "briefing-mailer",
  "version": "1.0.0",
  "description": "Minimal send-only MCP server: one send_email tool via the Gmail API over HTTPS",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "briefing-mailer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "get-token": "node scripts/get-refresh-token.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "google-auth-library": "10.7.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
